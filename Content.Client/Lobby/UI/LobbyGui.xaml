<lobbyUi:LobbyGui
    xmlns="https://spacestation14.io"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maths="clr-namespace:Robust.Shared.Maths;assembly=Robust.Shared.Maths"
    xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:vote="clr-namespace:Content.Client.Voting.UI"
    xmlns:style="clr-namespace:Content.Client.Stylesheets"
    xmlns:lobbyUi="clr-namespace:Content.Client.Lobby.UI"
    xmlns:info="clr-namespace:Content.Client.Info"
    xmlns:widgets="clr-namespace:Content.Client.UserInterface.Systems.Chat.Widgets">
    <!-- Background -->
    <TextureRect Access="Public" VerticalExpand="True" HorizontalExpand="True" Name="Background"
                 Stretch="KeepAspectCovered" />
    <BoxContainer Name="MainContainer" VerticalExpand="True" HorizontalExpand="True" Orientation="Horizontal"
                  Margin="10 10 10 10" SeparationOverride="2">
        <SplitContainer State="Auto" ResizeMode="NotResizable" HorizontalExpand="True">
            <!-- LHS Controls -->
            <BoxContainer Name="LeftSide" Orientation="Vertical" SeparationOverride="4" HorizontalExpand="True">
                <Control Name="DefaultState" VerticalExpand="True">
                    <BoxContainer Name="TopLeft" Orientation="Vertical">
                        <!-- Left Top Panel -->
                        <PanelContainer HorizontalAlignment="Left"
                                        Name="LeftSideTop"
                                        VerticalAlignment="Top">
                            <PanelContainer.PanelOverride>
                                <graphics:StyleBoxFlat BackgroundColor="#120A0AE6"
                                                    BorderColor="#7A6135"
                                                    BorderThickness="2"
                                                    ContentMarginLeftOverride="6"
                                                    ContentMarginRightOverride="6"
                                                    ContentMarginTopOverride="6"
                                                    ContentMarginBottomOverride="6" />
                            </PanelContainer.PanelOverride>
                            <BoxContainer Orientation="Vertical" HorizontalAlignment="Center" MaxWidth="800">
                                <info:LinkBanner Name="LinkBanner" VerticalExpand="false" HorizontalAlignment="Center"
                                                 Margin="3 3 3 3" />
                                <controls:StripeBack>
                                    <BoxContainer Orientation="Horizontal" SeparationOverride="6" Margin="3 3 3 3">
                                        <cc:UICommandButton Command="observe" Name="ObserveButton" Access="Public"
                                                            Text="{Loc 'ui-lobby-observe-button'}"
                                                            StyleClasses="CrescentButton"
                                                            WindowType="{x:Type lobbyUi:ObserveWarningWindow}" />
                                        <Label Name="StartTime"
                                               Access="Public"
                                               Align="Left"
                                               FontColorOverride="{x:Static maths:Color.DarkGray}"
                                               StyleClasses="LabelBig" HorizontalExpand="True" />
                                        <Button Name="ManifestButton" Access="Public"
                                                Text="Manifest"
                                                StyleClasses="CrescentButton" MinWidth="137" />
                                        <Button Name="ReadyButton" Access="Public" ToggleMode="True"
                                                Text="{Loc 'ui-lobby-ready-up-button'}"
                                                StyleClasses="CrescentButton" MinWidth="137" />
                                    </BoxContainer>
                                </controls:StripeBack>
                            </BoxContainer>
                        </PanelContainer>
                        <!-- Voting Popups -->
                        <BoxContainer Orientation="Vertical" SeparationOverride="4" Name="VoteContainer"
                                      Access="Public" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0 8" />
                    </BoxContainer>
                    <!-- Vertical Padding-->
                    <Control VerticalExpand="True" />
                    <!-- Left Bot Panel -->
                    <BoxContainer Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" SeparationOverride="4">
                        <info:DevInfoBanner Name="DevInfoBanner" VerticalExpand="false" Margin="3 3 3 3" />
                        <PanelContainer Name="LobbySongPanel">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#120A0AE6"
                                                BorderColor="#7A6135"
                                                BorderThickness="2"
                                                ContentMarginLeftOverride="4"
                                                ContentMarginRightOverride="4"
                                                ContentMarginTopOverride="2"
                                                ContentMarginBottomOverride="2" />
                        </PanelContainer.PanelOverride>
                            <RichTextLabel Name="LobbySong" Access="Public" HorizontalAlignment="Center" />
                        </PanelContainer>
                        <PanelContainer Name="LobbyBackgroundPanel">
                            <PanelContainer.PanelOverride>
                                <graphics:StyleBoxFlat BackgroundColor="#120A0AE6"
                                                    BorderColor="#7A6135"
                                                    BorderThickness="2"
                                                    ContentMarginLeftOverride="4"
                                                    ContentMarginRightOverride="4"
                                                    ContentMarginTopOverride="2"
                                                    ContentMarginBottomOverride="2" />
                            </PanelContainer.PanelOverride>
                            <RichTextLabel Name="LobbyBackground" Access="Public" HorizontalAlignment="Center" />
                        </PanelContainer>
                    </BoxContainer>
                </Control>
                <!-- Character setup state -->
                <!-- This is injected on startup. Funky! -->
                <Control Access="Public" Visible="False" Name="CharacterSetupState" VerticalExpand="True" />
            </BoxContainer>
            <!-- Right Panel -->
            <PanelContainer Name="RightSide"
                            HorizontalAlignment="Right"
                            VerticalExpand="True"
                            VerticalAlignment="Stretch">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#120A0AE6"
                                        BorderColor="#7A6135"
                                        BorderThickness="2"
                                        ContentMarginLeftOverride="8"
                                        ContentMarginRightOverride="8"
                                        ContentMarginTopOverride="8"
                                        ContentMarginBottomOverride="8" />
                </PanelContainer.PanelOverride>

                <BoxContainer Orientation="Vertical"
                            HorizontalExpand="True"
                            VerticalExpand="True"
                            SeparationOverride="8">

                    <!-- GOLD HEADER -->
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#8A6A34"
                                                BorderColor="#B09155"
                                                BorderThickness="2"
                                                ContentMarginLeftOverride="10"
                                                ContentMarginRightOverride="10"
                                                ContentMarginTopOverride="6"
                                                ContentMarginBottomOverride="6" />
                        </PanelContainer.PanelOverride>

                        <BoxContainer Orientation="Horizontal"
                                    MinSize="0 40"
                                    Name="HeaderContainer"
                                    Access="Public"
                                    SeparationOverride="4">

                            <Label Margin="8 0 0 0"
                                StyleClasses="LabelHeadingBigger"
                                FontColorOverride="#1A1208"
                                VAlign="Center"
                                Text="{Loc 'ui-lobby-title'}" />

                            <Label Name="ServerName"
                                Access="Public"
                                StyleClasses="LabelHeadingBigger"
                                FontColorOverride="#1A1208"
                                VAlign="Center"
                                HorizontalExpand="True"
                                HorizontalAlignment="Center" />
                        </BoxContainer>
                    </PanelContainer>

                    <!-- BUTTON BAR -->
                    <BoxContainer Orientation="Horizontal"
                                MinSize="0 40"
                                HorizontalExpand="True"
                                SeparationOverride="-1">

                        <Button Name="AHelpButton"
                                Access="Public"
                                Text="{Loc 'ui-lobby-ahelp-button'}"
                                StyleClasses="CrescentButton"
                                HorizontalExpand="True" />

                        <vote:VoteCallMenuButton Name="CallVoteButton"
                                                StyleClasses="CrescentButton"
                                                HorizontalExpand="True" />

                        <Button Name="OptionsButton"
                                Access="Public"
                                Text="{Loc 'ui-lobby-options-button'}"
                                StyleClasses="CrescentButton"
                                HorizontalExpand="True" />

                        <Button Name="LeaveButton"
                                Access="Public"
                                Text="{Loc 'ui-lobby-leave-button'}"
                                StyleClasses="CrescentButton"
                                HorizontalExpand="True" />
                    </BoxContainer>

                    <!-- SERVER INFO -->
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#160D0DEB"
                                                BorderColor="#7A6135"
                                                BorderThickness="1"
                                                ContentMarginLeftOverride="10"
                                                ContentMarginRightOverride="10"
                                                ContentMarginTopOverride="8"
                                                ContentMarginBottomOverride="10" />
                        </PanelContainer.PanelOverride>

                        <BoxContainer Orientation="Vertical">
                            <controls:NanoHeading Text="{Loc 'ui-lobby-server-info-block'}" />

                            <info:ServerInfo Name="ServerInfo"
                                            Access="Public"
                                            MinSize="0 30"
                                            VerticalExpand="false"
                                            Margin="3 6 3 3"
                                            MaxWidth="400"
                                            HorizontalAlignment="Left" />

                            <Label Name="StationTime"
                                Access="Public"
                                FontColorOverride="{x:Static maths:Color.LightGray}"
                                Margin="3 4 3 3"
                                HorizontalAlignment="Left" />
                        </BoxContainer>
                    </PanelContainer>

                    <!-- CHARACTER -->
                    <PanelContainer>
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#1A0505"
                                                BorderColor="#7A6135"
                                                BorderThickness="1"
                                                ContentMarginLeftOverride="10"
                                                ContentMarginRightOverride="10"
                                                ContentMarginTopOverride="8"
                                                ContentMarginBottomOverride="10" />
                        </PanelContainer.PanelOverride>

                        <BoxContainer Orientation="Vertical"
                                    MinHeight="185">
                            <lobbyUi:LobbyCharacterPreviewPanel Name="CharacterPreview"
                                                                Access="Public" />
                        </BoxContainer>
                    </PanelContainer>

                    <!-- CHAT -->
                    <PanelContainer VerticalExpand="True">
                        <PanelContainer.PanelOverride>
                            <graphics:StyleBoxFlat BackgroundColor="#080404F5"
                                                BorderColor="#7A6135"
                                                BorderThickness="2"
                                                ContentMarginLeftOverride="6"
                                                ContentMarginRightOverride="6"
                                                ContentMarginTopOverride="6"
                                                ContentMarginBottomOverride="6" />
                        </PanelContainer.PanelOverride>

                        <BoxContainer Orientation="Vertical"
                                    VerticalExpand="True"
                                    SeparationOverride="4">

                            <!-- TERMINAL HEADER -->
                            <PanelContainer>
                                <PanelContainer.PanelOverride>
                                    <graphics:StyleBoxFlat BackgroundColor="#1A120C"
                                                        BorderColor="#7A6135"
                                                        BorderThickness="1"
                                                        ContentMarginLeftOverride="6"
                                                        ContentMarginRightOverride="6"
                                                        ContentMarginTopOverride="3"
                                                        ContentMarginBottomOverride="3" />
                                </PanelContainer.PanelOverride>

                                <BoxContainer Orientation="Horizontal">
                                    <Label Text="LOCAL LOG"
                                        FontColorOverride="#B09155"
                                        StyleClasses="LabelHeading" />

                                    <Control HorizontalExpand="True" />

                                    <Label Text="SYSTEM: TAYPAN"
                                        FontColorOverride="#6F5B37" />
                                </BoxContainer>
                            </PanelContainer>

                            <!-- INNER CRT FRAME -->
                            <PanelContainer VerticalExpand="True">
                                <PanelContainer.PanelOverride>
                                    <graphics:StyleBoxFlat BackgroundColor="#000000"
                                                        BorderColor="#8C6A32"
                                                        BorderThickness="2"
                                                        ContentMarginLeftOverride="6"
                                                        ContentMarginRightOverride="6"
                                                        ContentMarginTopOverride="6"
                                                        ContentMarginBottomOverride="6" />
                                </PanelContainer.PanelOverride>

                                <widgets:ChatBox Name="Chat"
                                                Access="Public"
                                                VerticalExpand="True"
                                                Margin="0 0 0 0"
                                                MinHeight="50" />
                            </PanelContainer>

                            <!-- FOOTER STATUS BAR -->
                            <PanelContainer>
                                <PanelContainer.PanelOverride>
                                    <graphics:StyleBoxFlat BackgroundColor="#120B08"
                                                        BorderColor="#7A6135"
                                                        BorderThickness="1"
                                                        ContentMarginLeftOverride="6"
                                                        ContentMarginRightOverride="6"
                                                        ContentMarginTopOverride="2"
                                                        ContentMarginBottomOverride="2" />
                                </PanelContainer.PanelOverride>

                                <BoxContainer Orientation="Horizontal">
                                    <Label Text="STATUS: CONNECTED"
                                        FontColorOverride="#B09155" />

                                    <Control HorizontalExpand="True" />

                                    <Label Text="CHANNEL: OOC"
                                        FontColorOverride="#6F5B37" />
                                </BoxContainer>
                            </PanelContainer>

                        </BoxContainer>
                    </PanelContainer>

                </BoxContainer>
            </PanelContainer>
        </SplitContainer>
    </BoxContainer>
</lobbyUi:LobbyGui>
