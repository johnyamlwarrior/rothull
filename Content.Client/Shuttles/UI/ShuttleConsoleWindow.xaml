<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
                      xmlns:ui="clr-namespace:Content.Client.Shuttles.UI"
                      xmlns:shuttle="clr-namespace:Content.Client._Crescent.Shuttle"
                      xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
                      Title="{Loc 'shuttle-console-window-title'}"
                      SetSize="960 762"
                      MinSize="960 762">
    <BoxContainer Orientation="Vertical"
                  Margin="6">
        <!-- Top row mode buttons -->
        <PanelContainer HorizontalExpand="True"
                        Margin="0 0 0 6">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#120A0AF2"
                                       BorderColor="#7A6135"
                                       BorderThickness="1"
                                       ContentMarginLeftOverride="6"
                                       ContentMarginRightOverride="6"
                                       ContentMarginTopOverride="6"
                                       ContentMarginBottomOverride="6" />
            </PanelContainer.PanelOverride>
            <BoxContainer Name="ModeButtons"
                          Orientation="Horizontal"
                          HorizontalAlignment="Stretch"
                          MinSize="52 52"
                          SeparationOverride="6">
                <Button Name="NavModeButton"
                        ToggleMode="True"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        Text="NAV" />
                <Button Name="MapModeButton"
                        ToggleMode="True"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        Text="MAP" />
                <Button Name="DockModeButton"
                        ToggleMode="True"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        Text="DOCK" />
                <Button Name="CrewManagementButton"
                        ToggleMode="True"
                        HorizontalExpand="True"
                        VerticalExpand="True"
                        Text="CREW" />
            </BoxContainer>
        </PanelContainer>
        <!-- Contents box -->
        <PanelContainer HorizontalExpand="True"
                        VerticalExpand="True">
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#0B0606F2"
                                       BorderColor="#7A6135"
                                       BorderThickness="2"
                                       ContentMarginLeftOverride="6"
                                       ContentMarginRightOverride="6"
                                       ContentMarginTopOverride="6"
                                       ContentMarginBottomOverride="6" />
            </PanelContainer.PanelOverride>

            <BoxContainer Name="Contents"
                          HorizontalAlignment="Stretch"
                          VerticalExpand="True">
                <ui:NavScreen Name="NavContainer" Visible="False"/>
                <ui:MapScreen Name="MapContainer" Visible="False"/>
                <ui:DockingScreen Name="DockContainer" Visible="False"/>
                <shuttle:CrewScreen Name="CrewContainer" Visible="False"/>
            </BoxContainer>
        </PanelContainer>
    </BoxContainer>
</controls:FancyWindow>
